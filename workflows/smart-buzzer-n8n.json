    {
      "parameters": {
        "respondWith": "text",
        "responseBody": "=<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<Response>\n  <Play digits=\"w{{ $json.unlockDigit }}\"/>\n  <Pause length=\"2\"/>\n  <Say>Access granted</Say>\n</Response>",
        "options": {
          "responseHeaders": {
