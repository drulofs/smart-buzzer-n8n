    {
      "parameters": {
        "respondWith": "text",
        "responseBody": "=<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<Response>\n  <Gather input=\"speech\" action=\"{{ $json.headers['x-forwarded-proto'] }}://{{ $json.headers.host }}/webhook/{{ $json.webhookUrl.split('/webhook/')[1] }}\" speechTimeout=\"auto\" language=\"en-US\">\n    <Say>Please say the magic word</Say>\n  </Gather>\n  <Hangup/>\n</Response>",
        "options": {
          "responseHeaders": {
            "entries": [
              {
                "name": "Content-Type",
                "value": "text/xml"
              }
            ]
          }
        }
      },
      "id": "00000000-0000-4000-8000-000000000005",
